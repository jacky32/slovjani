@startuml "Sitemap Diagram"
!theme plain
hide empty members
hide circles

' Style definitions for clarity
skinparam class {
    BackgroundColor<<Public>> LightBlue
    BackgroundColor<<Admin>> Moccasin
    BorderColor Black
}

title Website Structure

' Main navigation hub
class "Homepage" as Home <<Public>>

' --- PUBLIC SECTION ---
package "Public section" {
    class "About us" as Onas <<Public>> {
        + Association description
        + Photo gallery
        --
        # Links to other pages
    }

    class "Posts (Public)" as PostsPub <<Public>> {
        + List of published posts
    }

    class "Activities (Public)" as CinnostPub <<Public>> {
        + Event calendar
        + List of public events
    }
}

' --- ADMIN SECTION ---
package "Admin section (Login required)" {
    class "Login / Auth" as Login <<Admin>> {
        + login()
        + logout()
    }

    class "Posts (Internal)" as AdminPostsPage <<Admin>> {
        + Post management
    }

    class "Kontakty" as Kontakty <<Admin>> {
        + List of all members
        + Member detail
    }

    class "Activities (Internal)" as CinnostPriv <<Admin>> {
        + Meeting minutes
        + Calendar (complete)
        + Public events
        + Private events
    }

    class "Voting" as Hlasovani <<Admin>> {
        - Voting topic
        - Options: For / Against / Abstain
        --
        + Admin: creates voting
        + Admin: closes voting
        + User: votes
    }
}

' Vztahy a navigace
Home --> Onas
Home --> PostsPub
Home --> CinnostPub
Home --> Login

Login ..> CinnostPriv : after login
Login ..> Hlasovani
Login ..> Kontakty
Login ..> AdminPostsPage

' Notes for logic explanation
note right of Hlasovani
  VOTING LOGIC:
  - Admin starts/closes
  - Users cannot see WHO voted how
  - Everyone only sees the totals
end note

@enduml
