@startuml "Sitemap Diagram"
!theme plain
hide empty members
hide circles

skinparam class {
    BorderColor Black
    BackgroundColor<<Public>> #d6ecff
    BackgroundColor<<Auth>> #f3e7cb
    BackgroundColor<<Admin>> #f5deb3
}

title Website Structure and Main Routes

class "Homepage\n/" as Home <<Public>>

package "Public Section" {
    class "About\n/" as PublicHome <<Public>> {
        + Association description
        + Photo gallery
        + Links to other pages
    }

    class "Posts (Public)\n/posts\n/posts/:id" as PublicPosts <<Public>> {
        + list of published posts
        + post detail
    }

    class "Activities (Public)\n/events\n/events/:id" as PublicEvents <<Public>> {
        + public events calendar
        + event detail
    }
}

package "Authentication" {
    class "Login\n/login" as Login <<Auth>> {
        + GET new
        + POST create
        + optional bootstrap default admin
    }

    class "Logout\n/logout" as Logout <<Auth>> {
        + POST destroy
    }
}

package "Admin Section (login required)" {
    class "Posts (Internal)\n/admin/posts" as AdminPosts <<Admin>> {
        + CRUD
        + comment threads
        + attachments
    }

    class "Activities (Internal)\n/admin/events" as AdminEvents <<Admin>> {
        + CRUD
        + public and private events
        + comment threads
        + attachments
    }

    class "Voting\n/admin/votings" as AdminVotings <<Admin>> {
        + voting CRUD
        + questions (/questions)
        + user votes (/users_questions)
        + comment threads
        + attachments
    }

    class "Contacts / Users\n/admin/users" as AdminUsers <<Admin>> {
        + members list
        + member detail
        + user management
        + comment threads
        + attachments
    }

    class "Preview API\n/admin/previews/preview_markup" as AdminPreview <<Admin>> {
        + POST preview_markup
    }
}

class "Fallback\n404" as NotFound <<Auth>> {
    + ErrorsController#notFound
}

Home --> PublicHome
Home --> PublicPosts
Home --> PublicEvents
Home --> Login

Login ..> Logout : after login
Login ..> AdminPosts : after login
Login ..> AdminEvents : after login
Login ..> AdminVotings : after login
Login ..> AdminUsers : after login
AdminPosts --> AdminPreview : markup preview
AdminEvents --> AdminPreview : markup preview
AdminVotings --> AdminPreview : markup preview

note right of AdminVotings
    Voting logic:
    - admin creates and closes voting
    - voting is done per question: YES/NO/ABSTAIN
    - system shows totals, not who voted what
end note

note bottom of NotFound
    If route is not found,
    Router returns ErrorsController#notFound.
end note

@enduml
