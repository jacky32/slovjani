@startuml "Sitemap Diagram"
!theme plain
hide empty members

' Definice stylů pro přehlednost
skinparam class {
    BackgroundColor<<Public>> LightBlue
    BackgroundColor<<Admin>> Moccasin
    BorderColor Black
}

title Struktura webu

' Hlavní rozcestník
class "Homepage" as Home <<Public>>

' --- VEŘEJNÁ SEKCE ---
package "Veřejná sekce" {
    class "O nás" as Onas <<Public>> {
        + Popis spolku
        + Fotogalerie
        --
        # Odkazy na další stránky
    }

    class "Činnost (Veřejná)" as CinnostPub <<Public>> {
        + Kalendář akcí
        + Seznam veřejných akcí
    }
}

' --- ADMINISTRAČNÍ SEKCE ---
package "Administrační sekce (Login required)" {
    class "Login / Auth" as Login <<Admin>> {
        + přihlásit()
        + odhlásit()
    }

    class "Administrativa" as AdminPage <<Admin>> {
        + Nastavení systému
    }

    class "Kontakty" as Kontakty <<Admin>> {
        + Seznam všech členů
        + Detail člena
    }

    class "Činnost (Interní)" as CinnostPriv <<Admin>> {
        + Zápisy o schůzích
        + Kalendář (kompletní)
        + Veřejné akce
        + Soukromé akce
    }

    class "Hlasování" as Hlasovani <<Admin>> {
        - Téma hlasování
        - Možnosti: Pro / Proti / Zdržel se
        - Stav: Aktivní / Uzavřeno
        --
        + Admin: vytváří hlasování
        + Admin: uzavírá hlasování
        + User: hlasuje
    }
}

' Vztahy a navigace
Home --> Onas
Home --> CinnostPub
Home --> Login

Login ..> CinnostPriv : po přihlášení
Login ..> Hlasovani
Login ..> Kontakty
Login ..> AdminPage

' Poznámky pro vysvětlení logiky
note right of Hlasovani
  LOGIKA HLASOVÁNÍ:
  - Admin startuje/uzavírá
  - Uživatelé nevidí, KDO jak hlasoval
  - Všichni vidí pouze součty
end note

@enduml
